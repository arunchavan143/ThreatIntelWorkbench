{
    "env": {
        "node": true,
        "browser": true,
        "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": 12
    },
    "rules": {
        "no-unused-vars": "warn",
        "no-undef": "off",
        "no-console": "off",
        "no-prototype-builtins": "off",
        "no-empty": "warn"
    }
}
